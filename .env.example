PORT=3000

# 如果上游 key 是 Netlify 短效 key，优先只配置 NETLIFY_URL。
# 网关会请求 ${NETLIFY_URL}/api/config 获取 gatewayKey，并自动使用 ${NETLIFY_URL}/.netlify/ai/v1。
NETLIFY_URL=https://stellar-quokka-2fdb2f.netlify.app
NETLIFY_KEY_TTL_SECONDS=300
NETLIFY_CONFIG_TIMEOUT_SECONDS=15

# 静态上游模式：不配置 NETLIFY_URL 时使用。
UPSTREAM_BASE_URL=https://stellar-quokka-2fdb2f.netlify.app/.netlify/ai/v1
UPSTREAM_API_KEY=

# 生产环境建议显式填写公网域名，例如 https://img-gateway.example.com
PUBLIC_BASE_URL=

# 设置后，访问 /v1/* 需要 Authorization: Bearer <GATEWAY_API_KEY>
GATEWAY_API_KEY=

# 管理台地址：/admin
# 建议生产环境必须设置 ADMIN_PASSWORD，浏览器会弹出 Basic Auth 登录框。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_TOKEN=
ADMIN_STORE_FILE=data/admin-store.json
MAX_LOG_ENTRIES=5000

DEFAULT_IMAGE_MODEL=gpt-image-2
STORAGE_DIR=data/uploads
FILE_ROUTE_PREFIX=/uploads
TEMP_FILE_TTL_SECONDS=86400
CLEANUP_INTERVAL_SECONDS=3600
MAX_UPLOAD_BYTES=20mb
MAX_STORAGE_BYTES=10gb
MAX_STORED_FILES=5000
MAX_IMAGES=16
BODY_LIMIT=30mb
REQUEST_TIMEOUT_SECONDS=300

# 调试用：开启后把上游返回的最终图片额外保存到 DEBUG_OUTPUT_DIR
DEBUG_SAVE_OUTPUT_IMAGES=false
DEBUG_OUTPUT_DIR=output

# 可选：把客户端模型名映射到上游模型名，例如 {"gpt-image-1":"gpt-image-2"}
MODEL_ALIASES={}

# Vercel 部署建议保持 auto；检测到 BLOB_READ_WRITE_TOKEN 时自动使用 Vercel Blob。
# 未配置 Blob 时会退回本地临时目录，部署在 Vercel 上不适合作为稳定图床。
STORAGE_PROVIDER=auto
BLOB_READ_WRITE_TOKEN=
BLOB_PREFIX=image-api
BLOB_CACHE_CONTROL_MAX_AGE_SECONDS=3600
